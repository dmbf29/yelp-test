<div class="container mt-5">
  <h1>Add a New Restaurant</h1>
  <%= simple_form_for @restaurant do |f| %>
    <%= f.input :name %>
    <%= f.input :address %>
    <%= f.input :phone_number %>
    <%= f.input :category %>
    <%= f.button :submit, class: "btn btn-primary" %>
  <% end %>
  <div class="mt-3">
    <%= link_to "Back to Restaurants", restaurants_path, class: "btn btn-outline-secondary" %>
  </div>
</div>
