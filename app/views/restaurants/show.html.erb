<div class="container mt-5">
  <div class="row">
    <div class="col-md-8">
      <h1><%= @restaurant.name %></h1>
      <div class="card mb-4">
        <div class="card-body">
          <p><strong>Category:</strong> <%= @restaurant.category %></p>
          <p><strong>Address:</strong> <%= @restaurant.address %></p>
          <p><strong>Phone:</strong> <%= @restaurant.phone_number %></p>
        </div>
      </div>
      <h2>Reviews</h2>
      <%= link_to "Add a Review", new_restaurant_review_path(@restaurant), class: "btn btn-primary mb-3" %>
      <% @restaurant.reviews.each do |review| %>
        <div class="card mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <h5 class="card-title">Rating: <%= "⭐" * review.rating %></h5>
              <small class="text-muted"><%= review.created_at.strftime("%B %d, %Y") %></small>
            </div>
            <p class="card-text"><%= review.content %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <div class="mt-3">
    <%= link_to "Back to Restaurants", restaurants_path, class: "btn btn-outline-secondary" %>
  </div>
</div>
