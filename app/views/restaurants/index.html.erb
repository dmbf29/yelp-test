<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Restaurants</h1>
    <%= link_to "Add a new restaurant", new_restaurant_path, class: "btn btn-primary" %>
  </div>
  <div class="row">
    <% @restaurants.each do |restaurant| %>
      <div class="col-md-4 mb-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= restaurant.name %></h5>
            <p class="card-text">
              <strong>Category:</strong> <%= restaurant.category %><br>
              <strong>Address:</strong> <%= restaurant.address %><br>
              <strong>Phone:</strong> <%= restaurant.phone_number %>
            </p>
            <%= link_to "View Details", restaurant_path(restaurant), class: "btn btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
