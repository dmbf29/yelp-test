<div class="container mt-5">
  <h1>Add a Review for <%= @restaurant.name %></h1>
  <%= simple_form_for [@restaurant, @review] do |f| %>
    <%= f.input :rating, collection: 0..5, hint: "0 = not good at all, 5 = excellent!" %>
    <%= f.input :content %>
    <%= f.button :submit, "Submit Review", class: "btn btn-primary" %>
  <% end %>
  <div class="mt-3">
    <%= link_to "Back to Restaurant", restaurant_path(@restaurant), class: "btn btn-outline-secondary" %>
  </div>
</div>
